# Copy to .env and fill in. Never commit your real .env.

# PostgreSQL connection. URL-encode special chars in the password (# -> %23).
# DATABASE_URL = pooled connection (runtime). DIRECT_URL = direct (migrations).
# On Neon: DATABASE_URL = the "-pooler" host, DIRECT_URL = the non-pooler host.
# Drop "&channel_binding=require" from Neon strings — keep only ?sslmode=require.
# Locally, set both to the same local Postgres value.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/stockpilot?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/stockpilot?schema=public"

# Auth.js / next-auth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Claude API key (optional). If empty, the Reorder Advisor falls back to Gemini
# (below), then a transparent heuristic planner. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=""

# Google Gemini API key (optional, FREE — no credit card).
# Get one at https://aistudio.google.com/apikey. Used when ANTHROPIC_API_KEY is
# empty. If both are empty, the heuristic planner is used.
GEMINI_API_KEY=""

# Optional: override the advisor model.
# ADVISOR_MODEL="claude-sonnet-5"      # Claude (when ANTHROPIC_API_KEY is set)
# GEMINI_MODEL="gemini-flash-latest"   # Gemini (when GEMINI_API_KEY is set)
